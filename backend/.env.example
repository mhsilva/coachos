# Supabase > Settings > API > Project URL
SUPABASE_URL=https://xxxx.supabase.co

# Supabase > Settings > API > service_role key (NUNCA expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase > Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Origins permitidas (separar por vírgula, sem espaço)
ALLOWED_ORIGINS=http://localhost:5173,https://your-cf-pages-domain.pages.dev
